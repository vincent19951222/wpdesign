{
  "meta": {
    "headerType": "hand-drawn",
    "footerType": "hand-drawn",
    "author": "Creative Studio",
    "description": "A Playful Hand-drawn Style Demo"
  },
  "headerBar": {
    "backgroundColor": "#fff9c4",
    "color": "#5d4037",
    "padding": "15px 20px",
    "borderRadius": "15px 15px 0 0",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif",
    "fontSize": "14px",
    "display": "flex",
    "justifyContent": "space-between",
    "alignItems": "center",
    "borderBottom": "3px dashed #ffb347",
    "boxShadow": "0 4px 0 rgba(0,0,0,0.05)",
    "marginBottom": "20px"
  },
  "headerBarLeft": {
    "display": "flex",
    "alignItems": "center"
  },
  "headerBarRight": {
    "display": "flex",
    "alignItems": "center"
  },
  "headerMood": {
    "marginRight": "10px",
    "fontStyle": "italic"
  },
  "headerWifi": {},
  "headerPower": {
    "marginRight": "5px"
  },
  "headerBatteryBody": {
    "width": "25px",
    "height": "12px",
    "border": "2px solid #5d4037",
    "borderRadius": "6px",
    "padding": "2px",
    "display": "flex"
  },
  "headerBatteryLevel": {
    "width": "100%",
    "height": "100%",
    "backgroundColor": "#aed581",
    "borderRadius": "2px"
  },
  "wrapper": {
    "margin": "0 auto",
    "padding": "40px 30px",
    "backgroundColor": "#fffbf5",
    "border": "4px solid #2d2d2d",
    "borderRadius": "20px",
    "boxShadow": "8px 8px 0 #ffb347, 12px 12px 0 #2d2d2d",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif",
    "minHeight": "auto",
    "boxSizing": "border-box",
    "width": "100%",
    "maxWidth": "680px",
    "overflow": "hidden",
    "position": "relative"
  },
  "section": {
    "backgroundColor": "transparent",
    "padding": "0",
    "marginBottom": "30px",
    "boxSizing": "border-box"
  },
  "h1Container": {
    "textAlign": "center",
    "marginBottom": "40px",
    "position": "relative"
  },
  "h1": {
    "display": "inline-block",
    "background": "linear-gradient(135deg, #ff6b9d 0%, #ff8a80 100%)",
    "color": "#fff",
    "fontSize": "28px",
    "fontWeight": 700,
    "padding": "18px 35px",
    "border": "4px solid #2d2d2d",
    "borderRadius": "30px 10px 30px 10px",
    "boxShadow": "5px 5px 0 #ffeb3b, 8px 8px 0 #2d2d2d",
    "transform": "rotate(-1deg)",
    "textShadow": "2px 2px 0 rgba(0,0,0,0.2)",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif",
    "margin": "0"
  },
  "h1Subtitle": {
    "fontSize": "14px",
    "color": "#888",
    "marginTop": "15px",
    "fontStyle": "italic",
    "display": "block",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif"
  },
  "h2Container": {
    "textAlign": "center",
    "margin": "50px 0 25px 0"
  },
  "h2": {
    "display": "inline-block",
    "backgroundColor": "#fff9c4",
    "color": "#5d4037",
    "fontSize": "20px",
    "fontWeight": 700,
    "padding": "12px 25px",
    "border": "3px solid #2d2d2d",
    "borderRadius": "8px",
    "boxShadow": "4px 4px 0 #ffcc80",
    "transform": "rotate(1deg)",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif",
    "margin": "0",
    "position": "relative"
  },
  "h3Container": {
    "display": "flex",
    "alignItems": "center",
    "margin": "35px 0 15px 0"
  },
  "h3Badge": {
    "background": "linear-gradient(135deg, #4fc3f7 0%, #29b6f6 100%)",
    "color": "#fff",
    "fontWeight": 700,
    "fontSize": "12px",
    "padding": "6px 12px",
    "borderRadius": "20px",
    "marginRight": "12px",
    "border": "2px solid #2d2d2d",
    "boxShadow": "2px 2px 0 #2d2d2d",
    "display": "inline-block",
    "lineHeight": "1"
  },
  "h3": {
    "fontSize": "18px",
    "fontWeight": 700,
    "color": "#37474f",
    "borderBottom": "3px dashed #4fc3f7",
    "paddingBottom": "3px",
    "margin": "0",
    "display": "inline-block",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif"
  },
  "h4": {
    "fontSize": "16px",
    "fontWeight": 700,
    "color": "#455a64",
    "margin": "25px 0 12px 0",
    "paddingLeft": "15px",
    "borderLeft": "5px solid #ff7043",
    "background": "linear-gradient(90deg, #fff3e0 0%, transparent 100%)",
    "paddingTop": "5px",
    "paddingBottom": "5px",
    "lineHeight": "1.4"
  },
  "h5": {
    "fontSize": "15px",
    "fontWeight": 700,
    "color": "#546e7a",
    "margin": "20px 0 10px 0",
    "paddingLeft": "15px",
    "borderLeft": "5px solid #66bb6a",
    "background": "linear-gradient(90deg, #e8f5e9 0%, transparent 100%)",
    "paddingTop": "5px",
    "paddingBottom": "5px",
    "lineHeight": "1.4"
  },
  "p": {
    "fontSize": "16px",
    "lineHeight": "2",
    "color": "#37474f",
    "marginBottom": "18px",
    "textAlign": "justify"
  },
  "strong": {
    "background": "linear-gradient(180deg, transparent 50%, #ffeb3b 50%)",
    "fontWeight": 700,
    "padding": "0 3px",
    "color": "#2d2d2d"
  },
  "em": {
    "fontStyle": "italic",
    "color": "#7986cb",
    "fontWeight": 500
  },
  "code": {
    "background": "#e8f5e9",
    "color": "#2e7d32",
    "padding": "3px 8px",
    "borderRadius": "6px",
    "fontFamily": "'Comic Neue', monospace",
    "fontSize": "14px",
    "border": "2px dashed #81c784"
  },
  "a": {
    "color": "#e91e63",
    "textDecoration": "none",
    "fontWeight": 700,
    "borderBottom": "2px wavy #e91e63",
    "transition": "all 0.2s"
  },
  "blockquote": {
    "background": "#e3f2fd",
    "border": "3px solid #2d2d2d",
    "borderRadius": "20px 20px 20px 5px",
    "padding": "0",
    "margin": "25px 0",
    "boxShadow": "5px 5px 0 #90caf9",
    "overflow": "hidden",
    "position": "relative"
  },
  "blockquoteBadge": {
    "background": "linear-gradient(135deg, #42a5f5 0%, #1e88e5 100%)",
    "color": "#fff",
    "padding": "8px 16px",
    "fontSize": "12px",
    "fontWeight": 700,
    "display": "inline-block",
    "borderRadius": "15px",
    "margin": "15px 15px 0 15px",
    "border": "2px solid #2d2d2d",
    "fontFamily": "'Comic Neue', 'Noto Sans SC', cursive, sans-serif"
  },
  "blockquoteContent": {
    "padding": "15px 20px",
    "fontStyle": "italic",
    "color": "#1565c0"
  },
  "ul": {
    "listStyle": "none",
    "paddingLeft": "0",
    "margin": "20px 0",
    "fontSize": "16px",
    "lineHeight": "1.8",
    "color": "#37474f"
  },
  "ol": {
    "listStyle": "none",
    "paddingLeft": "0",
    "margin": "20px 0",
    "counterReset": "item",
    "fontSize": "16px",
    "lineHeight": "1.8",
    "color": "#37474f"
  },
  "liUl": {
    "display": "flex",
    "alignItems": "baseline",
    "marginBottom": "12px"
  },
  "liOl": {
    "display": "flex",
    "marginBottom": "12px"
  },
  "ulMarker": {
    "width": "14px",
    "height": "14px",
    "borderRadius": "50%",
    "marginRight": "12px",
    "flexShrink": 0,
    "border": "3px solid #2d2d2d",
    "background": "#f48fb1"
  },
  "olMarker": {
    "minWidth": "28px",
    "height": "28px",
    "background": "linear-gradient(135deg, #ba68c8 0%, #9c27b0 100%)",
    "color": "#fff",
    "fontFamily": "'Comic Neue', cursive",
    "fontWeight": 700,
    "fontSize": "14px",
    "display": "flex",
    "alignItems": "center",
    "justifyContent": "center",
    "marginRight": "12px",
    "borderRadius": "50%",
    "border": "2px solid #2d2d2d",
    "boxShadow": "2px 2px 0 #2d2d2d",
    "flexShrink": 0
  },
  "pre": {
    "margin": "25px 0",
    "background": "#263238",
    "border": "4px solid #2d2d2d",
    "borderRadius": "15px",
    "overflow": "hidden",
    "boxShadow": "6px 6px 0 #78909c",
    "textAlign": "left",
    "boxSizing": "border-box",
    "width": "100%"
  },
  "preHeader": {
    "background": "#37474f",
    "padding": "10px 15px",
    "display": "flex",
    "alignItems": "center",
    "gap": "8px",
    "borderBottom": "3px solid #455a64"
  },
  "preDot": {
    "width": "12px",
    "height": "12px",
    "borderRadius": "50%",
    "border": "2px solid #2d2d2d",
    "display": "inline-block"
  },
  "preBody": {
    "padding": "20px",
    "background": "#263238",
    "color": "#80cbc4",
    "fontFamily": "'Comic Neue', monospace",
    "fontSize": "14px",
    "lineHeight": "1.7",
    "overflowX": "auto",
    "whiteSpace": "pre"
  },
  "tableContainer": { "display": "block", "boxSizing": "border-box",
    "margin": "25px 0",
    "border": "4px solid #2d2d2d",
    "borderRadius": "12px",
    "overflow": "hidden",
    "boxShadow": "5px 5px 0 #b0bec5",
    "width": "100%",
    "overflowX": "auto"
  },
  "table": {
    "width": "100%",
    "borderCollapse": "collapse",
    "fontSize": "14px",
    "textAlign": "center"
  },
  "thead": {
    "background": "linear-gradient(135deg, #ffcc80 0%, #ffb74d 100%)"
  },
  "th": {
    "padding": "12px",
    "fontWeight": 700,
    "color": "#3e2723",
    "border": "2px solid #2d2d2d",
    "fontSize": "15px"
  },
  "td": {
    "padding": "12px",
    "border": "2px dashed #bdbdbd",
    "textAlign": "center",
    "background": "#fffde7",
    "color": "#263238"
  },
  "hrContainer": {
    "textAlign": "center",
    "margin": "40px 0",
    "position": "relative"
  },
  "hrText": {
    "fontSize": "24px",
    "color": "#90a4ae",
    "letterSpacing": "15px"
  },
  "footer": {
    "marginTop": "50px",
    "paddingTop": "25px",
    "borderTop": "3px dashed #90a4ae",
    "textAlign": "center"
  },
  "footerIcon": {
    "width": "50px",
    "height": "50px",
    "background": "linear-gradient(135deg, #ffab91 0%, #ff8a65 100%)",
    "margin": "0 auto 15px auto",
    "border": "3px solid #2d2d2d",
    "borderRadius": "50%",
    "display": "flex",
    "alignItems": "center",
    "justifyContent": "center",
    "fontSize": "24px",
    "boxShadow": "3px 3px 0 #2d2d2d"
  },
  "footerText": {
    "fontSize": "13px",
    "color": "#90a4ae",
    "fontStyle": "italic",
    "margin": "5px 0 20px 0"
  }
}
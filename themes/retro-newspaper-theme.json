{
    "meta": {
        "headerType": "retro",
        "footerType": "retro",
        "author": "Pixel Lab",
        "description": "Vintage newspaper style with serif fonts and ink vibes."
    },
    "headerBar": {
        "padding": "20px 0",
        "borderBottom": "3px double #1a1a1a",
        "marginBottom": "30px",
        "textAlign": "center",
        "backgroundColor": "transparent",
        "color": "#1a1a1a"
    },
    "wrapper": {
        "margin": "0",
        "padding": "20px",
        "backgroundColor": "#f4f1ea",
        "fontFamily": "'Times New Roman', Georgia, serif",
        "color": "#2c2c2c",
        "minHeight": "auto",
        "boxSizing": "border-box",
        "width": "100%",
        "maxWidth": "100%",
        "overflow": "hidden"
    },
    "section": {
        "backgroundColor": "transparent",
        "padding": "0 10px",
        "marginBottom": "30px",
        "boxSizing": "border-box"
    },
    "h1Container": {
        "textAlign": "center",
        "marginBottom": "40px",
        "lineHeight": "1.2"
    },
    "h1": {
        "display": "block",
        "color": "#1a1a1a",
        "fontSize": "32px",
        "fontWeight": 700,
        "margin": "0 0 15px 0",
        "lineHeight": "1.2",
        "fontFamily": "'Georgia', serif",
        "boxSizing": "border-box"
    },
    "h1Subtitle": {
        "fontSize": "14px",
        "color": "#555",
        "fontFamily": "'Courier New', monospace",
        "fontStyle": "italic",
        "display": "block"
    },
    "h2Container": {
        "textAlign": "center",
        "marginTop": "40px",
        "marginBottom": "25px",
        "lineHeight": "1.2"
    },
    "h2": {
        "display": "inline-block",
        "color": "#1a1a1a",
        "fontSize": "24px",
        "fontWeight": 700,
        "padding": "5px 20px",
        "borderTop": "2px solid #1a1a1a",
        "borderBottom": "2px solid #1a1a1a",
        "margin": "0",
        "fontFamily": "'Georgia', serif",
        "textTransform": "uppercase",
        "backgroundColor": "#e8e4db",
        "boxSizing": "border-box"
    },
    "h3Container": {
        "marginTop": "30px",
        "marginBottom": "15px",
        "display": "flex",
        "alignItems": "center"
    },
    "h3Badge": {
        "backgroundColor": "#1a1a1a",
        "color": "#f4f1ea",
        "fontWeight": "bold",
        "fontSize": "14px",
        "padding": "2px 8px",
        "marginRight": "10px",
        "display": "none",
        "lineHeight": "1"
    },
    "h3": {
        "fontSize": "20px",
        "fontWeight": 700,
        "color": "#1a1a1a",
        "margin": "0",
        "borderLeft": "5px solid #1a1a1a",
        "paddingLeft": "10px",
        "fontFamily": "'Georgia', serif",
        "display": "inline-block"
    },
    "h4": {
        "fontSize": "16px",
        "fontWeight": 700,
        "color": "#444",
        "margin": "20px 0 10px 0",
        "textDecoration": "underline",
        "textDecorationStyle": "double",
        "fontFamily": "'Courier New', monospace"
    },
    "h5": {
        "fontSize": "14px",
        "fontWeight": "bold",
        "color": "#666",
        "margin": "15px 0",
        "fontStyle": "italic",
        "fontFamily": "'Georgia', serif"
    },
    "p": {
        "fontSize": "18px",
        "lineHeight": "1.6",
        "color": "#2c2c2c",
        "marginBottom": "25px",
        "textAlign": "justify"
    },
    "strong": {
        "fontWeight": "bold",
        "color": "#000"
    },
    "em": {
        "fontStyle": "italic",
        "color": "#444"
    },
    "code": {
        "backgroundColor": "#e6e6e6",
        "color": "#1a1a1a",
        "padding": "2px 4px",
        "border": "1px dashed #333",
        "fontFamily": "'Courier New', monospace",
        "fontSize": "15px"
    },
    "a": {
        "color": "#8b0000",
        "textDecoration": "underline",
        "fontWeight": "bold"
    },
    "blockquote": {
        "backgroundColor": "transparent",
        "borderTop": "2px solid #1a1a1a",
        "borderBottom": "2px solid #1a1a1a",
        "padding": "20px 0",
        "margin": "30px 0",
        "fontSize": "22px",
        "fontWeight": "bold",
        "color": "#1a1a1a",
        "textAlign": "center",
        "fontFamily": "'Georgia', serif",
        "fontStyle": "italic",
        "lineHeight": "1.4",
        "boxSizing": "border-box"
    },
    "blockquoteBadge": {
        "display": "none"
    },
    "ul": {
        "paddingLeft": "20px",
        "marginBottom": "25px",
        "fontSize": "17px",
        "lineHeight": "1.8",
        "color": "#2c2c2c",
        "listStyleType": "square"
    },
    "ol": {
        "paddingLeft": "0",
        "marginBottom": "25px",
        "fontSize": "17px",
        "lineHeight": "1.8",
        "color": "#2c2c2c",
        "listStyleType": "none"
    },
    "liUl": {
        "marginBottom": "10px",
        "display": "list-item"
    },
    "liOl": {
        "marginBottom": "15px",
        "display": "flex",
        "alignItems": "flex-start"
    },
    "ulMarker": {},
    "olMarker": {
        "fontFamily": "'Times New Roman', serif",
        "fontSize": "24px",
        "lineHeight": "1",
        "fontWeight": "bold",
        "marginRight": "15px",
        "color": "#8b0000",
        "borderBottom": "2px solid #1a1a1a",
        "flexShrink": 0
    },
    "hrContainer": {
        "textAlign": "center",
        "margin": "40px 0"
    },
    "hrText": {
        "display": "inline-block",
        "width": "100%",
        "borderBottom": "1px solid #1a1a1a"
    },
    "pre": {
        "margin": "10px 0 30px 0",
        "padding": "15px",
        "border": "1px solid #1a1a1a",
        "backgroundColor": "#2c2c2c",
        "fontFamily": "'Courier New', monospace",
        "fontSize": "14px",
        "color": "#f4f1ea",
        "overflowX": "auto",
        "boxShadow": "5px 5px 0 #888",
        "textAlign": "left",
        "boxSizing": "border-box",
        "width": "100%"
    },
    "preBody": {
        "fontFamily": "'Courier New', monospace",
        "fontSize": "14px",
        "color": "#f4f1ea",
        "whiteSpace": "pre",
        "backgroundColor": "transparent"
    },
    "footer": {
        "marginTop": "60px",
        "padding": "30px 0",
        "textAlign": "center",
        "borderTop": "4px double #1a1a1a"
    },
    "footerIcon": {
        "fontSize": "30px",
        "marginBottom": "10px",
        "display": "block",
        "textAlign": "center"
    },
    "footerText": {
        "fontSize": "12px",
        "color": "#1a1a1a",
        "margin": "5px 0",
        "fontFamily": "'Courier New', monospace",
        "textTransform": "uppercase"
    },
    "tableContainer": {
        "margin": "20px 0",
        "border": "2px solid #1a1a1a",
        "background": "#fff",
        "width": "100%",
        "overflowX": "auto"
    },
    "table": {
        "width": "100%",
        "borderCollapse": "collapse",
        "fontSize": "15px",
        "textAlign": "left",
        "fontFamily": "'Courier New', monospace"
    },
    "thead": {
        "backgroundColor": "#1a1a1a",
        "color": "#f4f1ea"
    },
    "th": {
        "padding": "10px",
        "textTransform": "uppercase",
        "borderRight": "1px solid #f4f1ea"
    },
    "td": {
        "padding": "10px",
        "borderBottom": "1px solid #1a1a1a"
    }
}
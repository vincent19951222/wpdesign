{
    "meta": {
        "headerType": "neumorphism",
        "footerType": "neumorphism",
        "author": "Pixel Lab",
        "description": "Soft UI with gentle shadows and rounded corners."
    },
    "headerBar": {
        "backgroundColor": "#e0e5ec",
        "color": "#4d5b6e",
        "padding": "15px 20px",
        "borderRadius": "20px",
        "boxShadow": "9px 9px 16px rgb(163,177,198,0.6), -9px -9px 16px rgba(255,255,255, 0.5)",
        "fontSize": "14px",
        "display": "flex",
        "justifyContent": "space-between",
        "alignItems": "center",
        "marginBottom": "30px",
        "fontWeight": "bold",
        "letterSpacing": "1px"
    },
    "wrapper": {
        "margin": "0",
        "padding": "20px",
        "backgroundColor": "#e0e5ec",
        "fontFamily": "'Nunito', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif",
        "color": "#4d5b6e",
        "minHeight": "auto",
        "boxSizing": "border-box",
        "width": "100%",
        "maxWidth": "100%",
        "overflow": "hidden"
    },
    "section": {
        "backgroundColor": "#e0e5ec",
        "padding": "40px 25px",
        "borderRadius": "30px",
        "boxShadow": "20px 20px 60px #bec3c9, -20px -20px 60px #ffffff",
        "marginBottom": "30px",
        "boxSizing": "border-box"
    },
    "h1Container": {
        "textAlign": "center",
        "marginBottom": "50px",
        "lineHeight": "1.2"
    },
    "h1": {
        "display": "inline-block",
        "color": "#4d5b6e",
        "padding": "20px 30px",
        "borderRadius": "50px",
        "background": "#e0e5ec",
        "boxShadow": "5px 5px 10px #b8b9be, -5px -5px 10px #ffffff",
        "fontSize": "24px",
        "fontWeight": 800,
        "margin": "0",
        "lineHeight": "1.4",
        "letterSpacing": "0.5px",
        "boxSizing": "border-box"
    },
    "h1Subtitle": {
        "fontSize": "14px",
        "color": "#8ba2c4",
        "marginTop": "20px",
        "fontWeight": 500,
        "display": "block"
    },
    "h2Container": {
        "textAlign": "center",
        "marginTop": "50px",
        "marginBottom": "30px",
        "lineHeight": "1.2"
    },
    "h2": {
        "display": "inline-block",
        "color": "#6d5dfc",
        "fontSize": "18px",
        "fontWeight": 700,
        "padding": "12px 24px",
        "borderRadius": "12px",
        "background": "#e0e5ec",
        "boxShadow": "inset 3px 3px 7px #b8b9be, inset -3px -3px 7px #ffffff",
        "margin": "0",
        "boxSizing": "border-box"
    },
    "h3Container": {
        "marginTop": "30px",
        "marginBottom": "20px",
        "display": "flex",
        "alignItems": "center"
    },
    "h3Badge": {
        "backgroundColor": "#e0e5ec",
        "color": "#6d5dfc",
        "fontWeight": "bold",
        "fontSize": "14px",
        "padding": "6px 12px",
        "marginRight": "15px",
        "borderRadius": "10px",
        "boxShadow": "3px 3px 6px #b8b9be, -3px -3px 6px #ffffff",
        "display": "inline-block",
        "lineHeight": "1"
    },
    "h3": {
        "fontSize": "18px",
        "fontWeight": 700,
        "color": "#4d5b6e",
        "margin": "0",
        "display": "inline-block"
    },
    "h4": {
        "fontSize": "16px",
        "fontWeight": 700,
        "color": "#4d5b6e",
        "margin": "25px 0 15px 0",
        "paddingLeft": "15px",
        "borderLeft": "4px solid #6d5dfc",
        "borderRadius": "2px",
        "lineHeight": "1.4"
    },
    "h5": {
        "fontSize": "15px",
        "fontWeight": 600,
        "color": "#666",
        "margin": "15px 0",
        "lineHeight": "1.4"
    },
    "p": {
        "fontSize": "16px",
        "lineHeight": "1.8",
        "color": "#4d5b6e",
        "marginBottom": "25px",
        "textAlign": "justify",
        "textShadow": "1px 1px 1px #ffffff"
    },
    "strong": {
        "fontWeight": "bold",
        "color": "#333"
    },
    "em": {
        "fontStyle": "italic",
        "color": "#666"
    },
    "code": {
        "backgroundColor": "#e0e5ec",
        "color": "#6d5dfc",
        "padding": "2px 6px",
        "borderRadius": "4px",
        "fontFamily": "'Courier New', monospace",
        "fontSize": "14px",
        "boxShadow": "inset 2px 2px 5px #b8b9be, inset -2px -2px 5px #ffffff"
    },
    "a": {
        "color": "#6d5dfc",
        "textDecoration": "none",
        "borderBottom": "1px dashed #6d5dfc",
        "paddingBottom": "2px"
    },
    "blockquote": {
        "backgroundColor": "#e0e5ec",
        "borderRadius": "15px",
        "padding": "20px",
        "margin": "25px 0",
        "fontSize": "15px",
        "color": "#555",
        "boxShadow": "inset 4px 4px 8px #b8b9be, inset -4px -4px 8px #ffffff",
        "position": "relative",
        "overflow": "visible",
        "boxSizing": "border-box"
    },
    "blockquoteBadge": {
        "position": "absolute",
        "top": "-12px",
        "left": "20px",
        "backgroundColor": "#e0e5ec",
        "color": "#6d5dfc",
        "padding": "4px 12px",
        "fontSize": "12px",
        "fontWeight": "bold",
        "borderRadius": "20px",
        "boxShadow": "3px 3px 6px #b8b9be, -3px -3px 6px #ffffff",
        "display": "inline-block"
    },
    "ul": {
        "paddingLeft": "0",
        "marginBottom": "25px",
        "fontSize": "16px",
        "lineHeight": "1.8",
        "color": "#4d5b6e",
        "listStyleType": "none"
    },
    "ol": {
        "paddingLeft": "0",
        "marginBottom": "25px",
        "fontSize": "16px",
        "lineHeight": "1.8",
        "color": "#4d5b6e",
        "listStyleType": "none"
    },
    "liUl": {
        "marginBottom": "15px",
        "display": "flex",
        "alignItems": "baseline"
    },
    "liOl": {
        "marginBottom": "15px",
        "display": "flex",
        "alignItems": "center"
    },
    "ulMarker": {
        "width": "10px",
        "height": "10px",
        "borderRadius": "50%",
        "background": "#6d5dfc",
        "marginRight": "15px",
        "flexShrink": 0,
        "boxShadow": "2px 2px 4px #b8b9be, -2px -2px 4px #ffffff",
        "display": "inline-block"
    },
    "olMarker": {
        "width": "24px",
        "height": "24px",
        "borderRadius": "50%",
        "background": "#e0e5ec",
        "color": "#6d5dfc",
        "display": "flex",
        "alignItems": "center",
        "justifyContent": "center",
        "fontSize": "12px",
        "fontWeight": "bold",
        "marginRight": "15px",
        "flexShrink": 0,
        "boxShadow": "3px 3px 6px #b8b9be, -3px -3px 6px #ffffff"
    },
    "hrContainer": {
        "textAlign": "center",
        "margin": "40px 0",
        "opacity": 0.5
    },
    "hrText": {
        "display": "inline-block",
        "height": "2px",
        "background": "#e0e5ec",
        "boxShadow": "inset 1px 1px 2px #b8b9be, inset -1px -1px 2px #ffffff",
        "borderRadius": "2px",
        "width": "50%"
    },
    "pre": {
        "margin": "10px 0 30px 0",
        "padding": "15px",
        "borderRadius": "12px",
        "background": "#e0e5ec",
        "boxShadow": "inset 4px 4px 8px #b8b9be, inset -4px -4px 8px #ffffff",
        "textAlign": "left",
        "boxSizing": "border-box",
        "width": "100%",
        "overflow": "hidden"
    },
    "preBody": {
        "fontFamily": "'Courier New', monospace",
        "fontSize": "13px",
        "color": "#555",
        "whiteSpace": "pre",
        "overflowX": "auto",
        "backgroundColor": "transparent"
    },
    "footer": {
        "marginTop": "60px",
        "padding": "30px",
        "textAlign": "center",
        "borderTop": "1px solid rgba(0,0,0,0.05)"
    },
    "footerIcon": {
        "width": "50px",
        "height": "50px",
        "borderRadius": "50%",
        "background": "#e0e5ec",
        "margin": "0 auto 20px auto",
        "boxShadow": "5px 5px 10px #b8b9be, -5px -5px 10px #ffffff",
        "display": "flex",
        "alignItems": "center",
        "justifyContent": "center",
        "fontSize": "24px",
        "color": "#6d5dfc"
    },
    "footerText": {
        "fontSize": "12px",
        "color": "#8ba2c4",
        "margin": "5px 0",
        "letterSpacing": "1px"
    },
    "tableContainer": { "display": "block", "boxSizing": "border-box",
        "margin": "20px 0",
        "borderRadius": "15px",
        "background": "#e0e5ec",
        "overflow": "hidden",
        "boxShadow": "5px 5px 10px #b8b9be, -5px -5px 10px #ffffff",
        "width": "100%"
    },
    "table": {
        "width": "100%",
        "borderCollapse": "collapse",
        "fontSize": "14px",
        "textAlign": "left"
    },
    "thead": {
        "backgroundColor": "#e0e5ec",
        "borderBottom": "2px solid #d1d9e6"
    },
    "th": {
        "padding": "15px",
        "color": "#6d5dfc",
        "fontWeight": "bold"
    },
    "td": {
        "padding": "15px",
        "color": "#4d5b6e",
        "borderBottom": "1px solid #d1d9e6"
    }
}
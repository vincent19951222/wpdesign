{
    "meta": {
        "headerType": "magazine",
        "footerType": "magazine",
        "author": "Antigravity",
        "description": "High-end Fashion Magazine, Black/White/Gold"
    },
    "wrapper": {
        "backgroundColor": "#ffffff",
        "padding": "40px",
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "color": "#000000",
        "lineHeight": "1.8",
        "maxWidth": "680px",
        "margin": "0 auto"
    },
    "section": {
        "backgroundColor": "#ffffff",
        "padding": "0",
        "marginBottom": "20px"
    },
    "h1": {
        "fontFamily": "'Playfair Display', Georgia, serif",
        "fontSize": "36px",
        "fontWeight": "900",
        "color": "#000000",
        "textTransform": "uppercase",
        "textAlign": "center",
        "marginBottom": "20px",
        "letterSpacing": "2px",
        "paddingBottom": "20px",
        "borderBottom": "4px solid #D4AF37",
        "display": "block",
        "width": "100%",
        "boxSizing": "border-box"
    },
    "h1Subtitle": {
        "display": "block",
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "fontSize": "12px",
        "fontWeight": "bold",
        "color": "#999",
        "letterSpacing": "4px",
        "marginTop": "10px",
        "textTransform": "uppercase",
        "textAlign": "center"
    },
    "h2": {
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "fontSize": "24px",
        "fontWeight": "900",
        "color": "#000000",
        "textTransform": "uppercase",
        "borderBottom": "2px solid #000",
        "paddingBottom": "10px",
        "marginTop": "50px",
        "marginBottom": "30px",
        "letterSpacing": "1px",
        "display": "block",
        "width": "100%"
    },
    "h3": {
        "fontFamily": "'Playfair Display', Georgia, serif",
        "fontSize": "20px",
        "fontWeight": "bold",
        "color": "#000000",
        "fontStyle": "italic",
        "marginTop": "30px",
        "marginBottom": "20px",
        "display": "flex",
        "alignItems": "center"
    },
    "h3Badge": {
        "backgroundColor": "#000",
        "color": "#fff",
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "fontSize": "10px",
        "fontWeight": "bold",
        "textTransform": "uppercase",
        "padding": "4px 8px",
        "marginRight": "15px",
        "letterSpacing": "1px",
        "fontStyle": "normal",
        "display": "inline-block"
    },
    "h4": {
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "fontSize": "16px",
        "fontWeight": "bold",
        "color": "#D4AF37",
        "textTransform": "uppercase",
        "marginTop": "25px",
        "marginBottom": "15px",
        "letterSpacing": "1px",
        "paddingLeft": "20px",
        "borderLeft": "4px solid #000",
        "display": "block"
    },
    "h5": {
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "fontSize": "14px",
        "fontWeight": "bold",
        "color": "#666",
        "marginTop": "20px",
        "marginBottom": "10px",
        "letterSpacing": "1px",
        "display": "block"
    },
    "p": {
        "fontFamily": "'Georgia', serif",
        "fontSize": "17px",
        "color": "#333",
        "marginBottom": "25px",
        "textAlign": "justify",
        "lineHeight": "1.8"
    },
    "strong": {
        "fontWeight": "bold",
        "color": "#000",
        "background": "linear-gradient(120deg, transparent 60%, rgba(212, 175, 55, 0.3) 60%)",
        "padding": "0 4px"
    },
    "em": {
        "fontFamily": "'Playfair Display', Georgia, serif",
        "fontStyle": "italic",
        "color": "#D4AF37",
        "fontSize": "1.1em"
    },
    "code": {
        "fontFamily": "Consolas, monospace",
        "backgroundColor": "#f5f5f5",
        "color": "#000",
        "padding": "2px 6px",
        "border": "1px solid #ddd",
        "fontSize": "14px"
    },
    "a": {
        "color": "#000",
        "textDecoration": "none",
        "borderBottom": "1px solid #D4AF37",
        "fontWeight": "bold"
    },
    "blockquote": {
        "borderLeft": "4px solid #D4AF37",
        "backgroundColor": "#fffcf5",
        "margin": "30px 0",
        "padding": "0",
        "boxShadow": "10px 10px 0 #f0f0f0",
        "display": "block"
    },
    "blockquoteBadge": {
        "display": "inline-block",
        "backgroundColor": "#D4AF37",
        "color": "#fff",
        "padding": "5px 15px",
        "fontSize": "12px",
        "fontWeight": "bold",
        "textTransform": "uppercase",
        "letterSpacing": "1px",
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif"
    },
    "blockquoteContent": {
        "padding": "20px 20px 20px 30px",
        "fontFamily": "'Playfair Display', Georgia, serif",
        "fontSize": "18px",
        "fontStyle": "italic",
        "color": "#000",
        "lineHeight": "1.6"
    },
    "ul": {
        "listStyle": "none",
        "padding": "0",
        "marginBottom": "30px"
    },
    "liUl": {
        "position": "relative",
        "marginBottom": "15px",
        "fontFamily": "'Georgia', serif",
        "color": "#333",
        "display": "flex",
        "alignItems": "baseline"
    },
    "ulMarker": {
        "content": "'•'",
        "color": "#D4AF37",
        "fontSize": "24px",
        "lineHeight": "20px",
        "marginRight": "10px"
    },
    "ol": {
        "listStyle": "none",
        "padding": "0",
        "marginBottom": "30px"
    },
    "liOl": {
        "position": "relative",
        "marginBottom": "15px",
        "fontFamily": "'Georgia', serif",
        "color": "#333",
        "display": "flex",
        "alignItems": "center"
    },
    "olMarker": {
        "width": "24px",
        "height": "24px",
        "backgroundColor": "#000",
        "color": "#fff",
        "borderRadius": "50%",
        "textAlign": "center",
        "lineHeight": "24px",
        "fontSize": "12px",
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "fontWeight": "bold",
        "marginRight": "15px",
        "flexShrink": 0
    },
    "pre": {
        "backgroundColor": "#f9f9f9",
        "border": "1px solid #ddd",
        "margin": "30px 0",
        "display": "block"
    },
    "preHeader": {
        "backgroundColor": "#fff",
        "padding": "10px 20px",
        "borderBottom": "1px solid #ddd",
        "display": "flex",
        "justifyContent": "flex-end",
        "alignItems": "center"
    },
    "preBody": {
        "padding": "20px",
        "overflowX": "auto",
        "fontFamily": "Consolas, monospace",
        "fontSize": "13px",
        "color": "#333",
        "lineHeight": "1.6",
        "whiteSpace": "pre"
    },
    "tableContainer": { "display": "block", "boxSizing": "border-box",
        "margin": "30px 0",
        "overflowX": "auto"
    },
    "table": {
        "width": "100%",
        "borderCollapse": "collapse",
        "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif"
    },
    "thead": {
        "backgroundColor": "#000"
    },
    "th": {
        "backgroundColor": "#000",
        "color": "#fff",
        "fontWeight": "bold",
        "textTransform": "uppercase",
        "padding": "15px",
        "textAlign": "center",
        "fontSize": "12px",
        "letterSpacing": "1px"
    },
    "td": {
        "borderBottom": "1px solid #ddd",
        "padding": "15px",
        "color": "#333",
        "textAlign": "center",
        "fontSize": "14px",
        "backgroundColor": "#fff"
    },
    "hrContainer": {
        "textAlign": "center",
        "margin": "60px 0",
        "position": "relative"
    },
    "hrText": {
        "fontSize": "18px",
        "color": "#D4AF37",
        "backgroundColor": "#fff",
        "padding": "0 15px",
        "position": "relative",
        "zIndex": "1",
        "border": "1px solid #000",
        "display": "inline-block"
    },
    "footer": {
        "marginTop": "80px",
        "paddingTop": "30px",
        "textAlign": "center",
        "borderTop": "4px solid #D4AF37"
    },
    "footerIcon": {
        "fontSize": "30px",
        "color": "#000",
        "marginBottom": "15px",
        "display": "inline-block"
    },
    "footerText": {
        "fontFamily": "'Playfair Display', Georgia, serif",
        "fontStyle": "italic",
        "fontSize": "14px",
        "color": "#666",
        "display": "block"
    }
}
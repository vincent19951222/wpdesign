{
  "meta": {
    "headerType": "tech-min",
    "footerType": "tech-min",
    "author": "Antigravity",
    "description": "Soft Tech Minimalism, Light Surfaces with Precision Accents"
  },
  "wrapper": {
    "backgroundColor": "#f5f8fc",
    "padding": "20px",
    "fontFamily": "'SFMono-Regular', 'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif",
    "color": "#1f2937",
    "lineHeight": "1.75"
  },
  "section": {
    "backgroundColor": "#fcfdff",
    "padding": "24px 20px",
    "marginBottom": "20px",
    "border": "1px solid #dbe7f3",
    "borderRadius": "18px",
    "boxShadow": "0 10px 30px rgba(148, 163, 184, 0.10)"
  },
  "h1Container": {
    "textAlign": "center",
    "marginBottom": "34px",
    "lineHeight": "1.2"
  },
  "h1": {
    "fontFamily": "'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif",
    "fontSize": "28px",
    "fontWeight": "700",
    "color": "#0f172a",
    "borderBottom": "1px solid #c9d9ea",
    "paddingBottom": "14px",
    "marginBottom": "16px",
    "letterSpacing": "1px",
    "display": "block",
    "textAlign": "center"
  },
  "h1Subtitle": {
    "fontSize": "13px",
    "color": "#64748b",
    "marginTop": "0",
    "marginBottom": "0",
    "display": "block",
    "fontWeight": "500",
    "textAlign": "center",
    "letterSpacing": "0.6px",
    "textTransform": "uppercase"
  },
  "h2Container": {
    "textAlign": "left",
    "marginTop": "36px",
    "marginBottom": "18px",
    "lineHeight": "1.2"
  },
  "h2": {
    "fontFamily": "'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif",
    "fontSize": "21px",
    "fontWeight": "700",
    "color": "#164e63",
    "borderLeft": "4px solid #38bdf8",
    "paddingLeft": "12px",
    "margin": "0",
    "display": "block"
  },
  "h3Container": {
    "marginTop": "28px",
    "marginBottom": "14px",
    "display": "flex",
    "alignItems": "center"
  },
  "h3": {
    "fontSize": "18px",
    "fontWeight": "600",
    "margin": "0",
    "color": "#0f172a",
    "display": "inline-block"
  },
  "h3Badge": {
    "backgroundColor": "#e0f2fe",
    "color": "#0369a1",
    "border": "1px solid #7dd3fc",
    "fontSize": "11px",
    "fontWeight": "700",
    "padding": "2px 8px",
    "marginRight": "10px",
    "borderRadius": "999px",
    "display": "inline-block",
    "lineHeight": "1"
  },
  "h4": {
    "fontSize": "16px",
    "fontWeight": "600",
    "color": "#1e293b",
    "background": "linear-gradient(90deg, rgba(56, 189, 248, 0.12) 0%, rgba(255, 255, 255, 0) 100%)",
    "padding": "6px 10px",
    "marginTop": "20px",
    "marginBottom": "10px",
    "borderLeft": "3px solid #38bdf8",
    "display": "block"
  },
  "h5": {
    "fontSize": "14px",
    "fontWeight": "600",
    "color": "#475569",
    "marginTop": "16px",
    "marginBottom": "8px",
    "textDecoration": "underline",
    "textDecorationColor": "#bae6fd",
    "textUnderlineOffset": "4px",
    "display": "block"
  },
  "p": {
    "marginBottom": "18px",
    "textAlign": "justify",
    "color": "#334155",
    "fontSize": "16px",
    "lineHeight": "1.85"
  },
  "strong": {
    "color": "#0f172a",
    "fontWeight": "700",
    "background": "linear-gradient(180deg, rgba(255, 255, 255, 0) 55%, rgba(186, 230, 253, 0.8) 55%)",
    "padding": "0 2px"
  },
  "em": {
    "fontStyle": "italic",
    "color": "#0f766e"
  },
  "code": {
    "fontFamily": "'SFMono-Regular', Menlo, Monaco, monospace",
    "backgroundColor": "#eef6ff",
    "color": "#0f766e",
    "padding": "2px 6px",
    "borderRadius": "6px",
    "border": "1px solid #bfdbfe",
    "fontSize": "0.92em"
  },
  "a": {
    "color": "#0369a1",
    "textDecoration": "none",
    "borderBottom": "1px solid #7dd3fc"
  },
  "blockquote": {
    "margin": "22px 0",
    "padding": "0",
    "backgroundColor": "#f8fbff",
    "border": "1px solid #d7e9f7",
    "borderRadius": "14px",
    "display": "block"
  },
  "blockquoteBadge": {
    "display": "inline-block",
    "backgroundColor": "#e0f2fe",
    "color": "#075985",
    "fontSize": "12px",
    "padding": "6px 10px",
    "fontWeight": "700",
    "textTransform": "uppercase",
    "borderBottom": "1px solid #d7e9f7",
    "borderRight": "1px solid #d7e9f7",
    "borderTopLeftRadius": "14px",
    "borderBottomRightRadius": "10px"
  },
  "blockquoteContent": {
    "padding": "16px",
    "fontStyle": "italic",
    "color": "#475569",
    "borderTop": "1px solid #edf4fb"
  },
  "ul": {
    "listStyle": "none",
    "padding": "0",
    "marginBottom": "20px"
  },
  "liUl": {
    "position": "relative",
    "marginBottom": "10px",
    "display": "flex",
    "alignItems": "flex-start"
  },
  "ulMarker": {
    "display": "inline-block",
    "width": "8px",
    "height": "8px",
    "borderRadius": "999px",
    "backgroundColor": "#38bdf8",
    "marginRight": "10px",
    "marginTop": "10px",
    "flexShrink": 0
  },
  "ol": {
    "listStyle": "none",
    "padding": "0",
    "marginBottom": "20px"
  },
  "liOl": {
    "position": "relative",
    "marginBottom": "10px",
    "display": "flex",
    "alignItems": "flex-start"
  },
  "olMarker": {
    "color": "#0369a1",
    "fontSize": "12px",
    "fontWeight": "700",
    "backgroundColor": "#e0f2fe",
    "border": "1px solid #7dd3fc",
    "borderRadius": "999px",
    "padding": "2px 7px",
    "marginRight": "10px",
    "lineHeight": "normal"
  },
  "pre": {
    "backgroundColor": "#f8fbff",
    "border": "1px solid #d7e9f7",
    "borderRadius": "14px",
    "margin": "22px 0",
    "overflow": "hidden",
    "display": "block"
  },
  "preHeader": {
    "backgroundColor": "#eef6ff",
    "padding": "8px 12px",
    "borderBottom": "1px solid #d7e9f7",
    "display": "flex",
    "alignItems": "center",
    "gap": "8px"
  },
  "preDot": {
    "width": "10px",
    "height": "10px",
    "borderRadius": "50%",
    "backgroundColor": "#93c5fd"
  },
  "preBody": {
    "padding": "15px",
    "overflowX": "auto",
    "color": "#1e293b",
    "fontFamily": "'SFMono-Regular', Menlo, Monaco, monospace",
    "fontSize": "13px",
    "lineHeight": "1.6",
    "whiteSpace": "pre"
  },
  "tableContainer": {
    "display": "block",
    "boxSizing": "border-box",
    "overflowX": "auto",
    "margin": "22px 0",
    "border": "1px solid #d7e9f7",
    "borderRadius": "14px"
  },
  "table": {
    "width": "100%",
    "borderCollapse": "collapse",
    "backgroundColor": "#ffffff"
  },
  "thead": {
    "backgroundColor": "#eef6ff"
  },
  "th": {
    "backgroundColor": "#eef6ff",
    "color": "#075985",
    "fontWeight": "700",
    "textTransform": "uppercase",
    "padding": "12px",
    "borderBottom": "1px solid #d7e9f7",
    "textAlign": "left"
  },
  "td": {
    "padding": "12px",
    "borderBottom": "1px solid #edf4fb",
    "color": "#334155",
    "backgroundColor": "#ffffff"
  },
  "hrContainer": {
    "textAlign": "center",
    "margin": "40px 0",
    "position": "relative",
    "height": "20px"
  },
  "hrText": {
    "fontSize": "12px",
    "color": "#94a3b8",
    "letterSpacing": "4px",
    "backgroundColor": "#fcfdff",
    "padding": "0 10px",
    "position": "relative",
    "zIndex": "1"
  },
  "footer": {
    "marginTop": "60px",
    "paddingTop": "28px",
    "borderTop": "1px solid #d7e9f7",
    "textAlign": "center"
  },
  "footerIcon": {
    "fontSize": "24px",
    "color": "#38bdf8",
    "marginBottom": "10px",
    "display": "inline-block"
  },
  "footerText": {
    "fontSize": "12px",
    "color": "#64748b",
    "letterSpacing": "0.8px",
    "display": "block"
  }
}
